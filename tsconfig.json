{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "allowJs": true
  },
  "include": ["api/**/*", "utils/**/*", "types/**/*", "next-env.d.ts"],
  "exclude": ["node_modules"]
} 